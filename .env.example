DATABASE_URL=sqlite:///./data/app.db
APP_NAME=momo-trading
APP_VERSION=0.1.0
ENVIRONMENT=local
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# === KIS MCP 서버 ===
KIS_MCP_URL=http://localhost:3100/sse

# KIS API 인증 (MCP Docker에 전달)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_HTS_ID=
KIS_ACCT_STOCK=
KIS_PAPER_STOCK=
KIS_PROD_TYPE=01
KIS_ACCOUNT_TYPE=VIRTUAL

# KIS WebSocket
KIS_WS_URL_DOMESTIC=ws://ops.koreainvestment.com:21000
KIS_WS_URL_OVERSEAS=ws://ops.koreainvestment.com:31000

# === AI / LLM ===
LLM_PROVIDER=CLAUDE_CODE                  # CLAUDE_CODE / CODEX_CLI

# Claude Code CLI — 구독 크레딧 사용
CLAUDE_CODE_MODEL=sonnet              # 기본 모델 (Tier별 미지정 시 사용)
CLAUDE_CODE_MODEL_TIER1=haiku         # Tier1 (스캔/분석): 빠른 모델
CLAUDE_CODE_MODEL_TIER2=sonnet        # Tier2 (최종 검토): 정확한 모델
# CLAUDE_CODE_PATH=/opt/homebrew/bin/claude  # 비어있으면 자동 탐색

# Codex CLI
CODEX_MODEL=gpt-5.4
CODEX_MODEL_TIER1=gpt-5.4-mini
CODEX_MODEL_TIER2=gpt-5.4
CODEX_MODEL_ORCHESTRATOR=gpt-5.4
CODEX_REASONING_EFFORT=
CODEX_REASONING_EFFORT_TIER1=medium
CODEX_REASONING_EFFORT_TIER2=high
CODEX_REASONING_EFFORT_ORCHESTRATOR=xhigh
# CODEX_CLI_PATH=/opt/homebrew/bin/codex  # 비어있으면 자동 탐색
CODEX_DISABLE_MCP=true                  # 자동매매 LLM 호출은 사용자 Codex MCP 설정을 사용하지 않음

# === AI Agent ===
AUTONOMY_MODE=SEMI_AUTO
RECOMMENDATION_EXPIRE_MIN=60
MIN_BUY_QUANTITY=1

# === Trading Safety ===
TRADING_ENABLED=false
DAY_TRADING_ONLY=false                # true=당일 청산 필수, false=스윙 (유망 종목 오버나이트)
MAX_HOLD_DAYS_STABLE=5               # STABLE_SHORT 최대 보유일
MAX_HOLD_DAYS_AGGRESSIVE=3           # AGGRESSIVE_SHORT 최대 보유일
MAX_DAILY_TRADES=30
# MAX_SINGLE_ORDER_KRW / MAX_SINGLE_ORDER_USD: 미설정 시 AI 자율 결정

# === AI Risk Tuning ===
AI_RISK_TUNING_ENABLED=true
RISK_APPETITE=MODERATE
MIN_CASH_RATIO=0.05              # 최소 현금 비중 (0.05 = 5%, 빠른 대응용 여유금)

# === Scheduler ===
SCHEDULER_ENABLED=true
