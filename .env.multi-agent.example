DATABASE_URL=sqlite:///./data/app.multi-agent.db

# KIS API 인증 (MCP Docker에도 전달됨)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_HTS_ID=
KIS_ACCT_STOCK=
KIS_PAPER_STOCK=
KIS_ACCOUNT_TYPE=VIRTUAL

LLM_PROVIDER=CODEX_CLI
# 공통 추론 강도 (Codex/Claude 공유). 기본: T1=medium, T2/Orchestrator=xhigh.
LLM_EFFORT_TIER1=medium
LLM_EFFORT_TIER2=xhigh
LLM_EFFORT_ORCHESTRATOR=xhigh

RECOMMENDATION_EXPIRE_MIN=30

# === Trading Safety ===
TRADING_ENABLED=false
FORCE_LIQUIDATION_HOUR=15
FORCE_LIQUIDATION_MINUTE=10
MAX_HOLD_DAYS_STABLE=4
MAX_HOLD_DAYS_AGGRESSIVE=2
MAX_DAILY_TRADES=50
MAX_SINGLE_ORDER_KRW=3000000

# === AI Risk Tuning ===
MIN_CASH_RATIO=0.03
