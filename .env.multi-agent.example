DATABASE_URL=sqlite:///./data/app.multi-agent.db
APP_NAME=momo-trading
APP_VERSION=0.1.0
ENVIRONMENT=local
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:9200"]

# === KIS MCP 서버 ===
KIS_MCP_URL=http://localhost:3100/sse

# KIS API 인증
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_HTS_ID=
KIS_ACCT_STOCK=
KIS_PAPER_STOCK=
KIS_PROD_TYPE=01
KIS_ACCOUNT_TYPE=VIRTUAL

# KIS WebSocket
KIS_WS_URL_DOMESTIC=ws://ops.koreainvestment.com:21000
KIS_WS_URL_OVERSEAS=ws://ops.koreainvestment.com:31000

# === AI / LLM ===
LLM_PROVIDER=CODEX_CLI

# Claude Code CLI fallback
CLAUDE_CODE_MODEL=sonnet
CLAUDE_CODE_MODEL_TIER1=haiku
CLAUDE_CODE_MODEL_TIER2=sonnet
CLAUDE_CODE_PATH=

# Codex CLI
CODEX_MODEL=gpt-5.4
CODEX_MODEL_TIER1=gpt-5.4-mini
CODEX_MODEL_TIER2=gpt-5.4
CODEX_MODEL_ORCHESTRATOR=gpt-5.4
CODEX_REASONING_EFFORT=
CODEX_REASONING_EFFORT_TIER1=medium
CODEX_REASONING_EFFORT_TIER2=high
CODEX_REASONING_EFFORT_ORCHESTRATOR=xhigh
CODEX_CLI_PATH=
CODEX_DISABLE_MCP=true

# === AI Agent ===
AUTONOMY_MODE=SEMI_AUTO
RECOMMENDATION_EXPIRE_MIN=60
MIN_BUY_QUANTITY=1

# === Trading Safety ===
TRADING_ENABLED=false
DAY_TRADING_ONLY=false
MAX_HOLD_DAYS_STABLE=5
MAX_HOLD_DAYS_AGGRESSIVE=3
MAX_DAILY_TRADES=30
MAX_SINGLE_ORDER_KRW=0
MAX_SINGLE_ORDER_USD=0

# === AI Risk Tuning ===
AI_RISK_TUNING_ENABLED=true
RISK_APPETITE=MODERATE
MIN_CASH_RATIO=0.05

# === Scheduler ===
SCHEDULER_ENABLED=true
